# =============================================================================
# SOFRA ROYALE — Environment variables
# Copy to `.env` for local development. NEVER commit real values.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public site URL (no trailing slash). Used in emails, SEO, redirects.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Node environment is managed by Next.js; do not set NODE_ENV manually.

# -----------------------------------------------------------------------------
# Database (PostgreSQL — Supabase / Neon / Railway / local)
# -----------------------------------------------------------------------------
# Local example:  postgresql://postgres:postgres@localhost:5432/sofra_royale
# Pooled connection string (used by the app at runtime):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sofra_royale?schema=public"
# Direct (non-pooled) connection for migrations — required by some providers
# (Supabase/Neon with pgBouncer). Falls back to DATABASE_URL when identical.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sofra_royale?schema=public"

# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# Only needed behind a proxy or in non-Vercel production:
# AUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (Phase 3 — payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen` locally, or the dashboard webhook config in production:
STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Media uploads — Cloudinary (Phase 5 — admin uploads)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# -----------------------------------------------------------------------------
# Email — Gmail SMTP / Nodemailer (transactional email)
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_SECURE="true"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Sofra Royale <your-gmail-address@gmail.com>"

# -----------------------------------------------------------------------------
# SMS — Twilio (optional, Phase 6)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# -----------------------------------------------------------------------------
# Realtime — Pusher Channels (Phase 6 — live chat & order tracking)
# -----------------------------------------------------------------------------
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# -----------------------------------------------------------------------------
# Redis — Upstash (optional: rate limiting, cart cache)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Seed credentials (DEVELOPMENT ONLY — change before deploying)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@sofra-royale.example"
SEED_ADMIN_PASSWORD="Admin!Sofra2026"
SEED_CUSTOMER_EMAIL="demo@sofra-royale.example"
SEED_CUSTOMER_PASSWORD="Demo!Sofra2026"
